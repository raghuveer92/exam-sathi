# ExamSaathi Backend — local environment variables
# Copy this file to .env and fill in values.
# .env is git-ignored. Never commit real credentials.

# Supabase — Project Settings → Database → Connection string
#
# Local dev (IPv4-only Mac/network): Session pooler, port 5432
# DB_URL=jdbc:postgresql://aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# DB_USERNAME=postgres.YOUR_PROJECT_REF
#
# Render / cloud (IPv6): Direct connection, port 5432
# DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# DB_USERNAME=postgres
#
DB_URL=jdbc:postgresql://aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.sfqzrfbfhohjvpxwgtgu
DB_PASSWORD=<your_supabase_db_password>

# Legacy Render PostgreSQL (deprecated — migrate to Supabase)
# DB_URL=jdbc:postgresql://HOST.render.com:5432/exam_sathi_db?sslmode=require

DDL_AUTO=update
JWT_SECRET=<generate_a_strong_random_secret>
JWT_EXPIRATION=86400000

# Google Sign-In — comma-separated Web + Android OAuth client IDs
GOOGLE_OAUTH_CLIENT_IDS=705998749535-rg78efbe1kr64rppef6fd6vnpu98vvdj.apps.googleusercontent.com,705998749535-k8bolj448ag0es1rsg0njiqfd128m7ph.apps.googleusercontent.com

# Brevo transactional email (never commit the real API key)
BREVO_API_KEY=<your_brevo_api_key>
BREVO_VERIFICATION_BASE_URL=https://api.examsaathi.com/api
BREVO_PASSWORD_RESET_BASE_URL=https://app.examsaathi.com
